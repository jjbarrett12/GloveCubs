# CatalogOS — use same Supabase project as GloveCubs storefront
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-side (ingestion, publish): service role for full DB access
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Optional: when set, /api/ingest, /api/publish, /api/supplier-import, /dashboard require Authorization: Bearer <secret> or cookie catalogos_admin
# Required in production for supplier-import job APIs (start/list/approve/publish/resume/cancel).
# CATALOGOS_ADMIN_SECRET=your-admin-secret
# Dev only: allow suppliers with NULL organization_id to be used for import (default: deny)
# CATALOGOS_ALLOW_UNSCOPED_SUPPLIER_IMPORT=1
# Deferred AI matching (pass 2): chunk size per slice and max AI rows per serverless continuation before rescheduling
# CATALOGOS_AI_PASS2_CHUNK_SIZE=30
# CATALOGOS_AI_PASS2_MAX_PER_INVOCATION=120
# Legacy: inline AI inside runMatchingWithAIFallback (default false; use pass-2 worker instead)
# CATALOGOS_AI_MATCHING_INLINE_ENABLED=false
#
# Supplier import image enrichment (after normalization): optional HTTP JSON endpoint.
# Prefer {query} — each value is a single search phrase (rule-based + optional AI). Legacy: {sku}, {title}, {brand}.
# Example: https://your-worker.example.com/image-search?q={query}
# CATALOGOS_IMAGE_SEARCH_URL=
# Set to 0 to skip OpenAI query augmentation (rule-based queries only).
# CATALOGOS_IMAGE_SEARCH_AI_QUERIES=1
# Verify search result URLs with HEAD before storing (slower; stricter).
# CATALOGOS_IMAGE_ENRICH_VERIFY=0
#
# Optional: manufacturer JSON endpoint GET with {sku} → { image_url } (base SKU first, then variants in enrichment).
# CATALOGOS_MANUFACTURER_IMAGE_URL=https://your-worker.example.com/mfg-image?sku={sku}
#
# Optional: POST JSON { "url": "https://..." } → { "score": 0.92, "white_boost"?: 0.1 } to tune hero / white-background preference.
# CATALOGOS_IMAGE_SCORE_URL=
#
# Import auto-pricing: landed = supplier_cost + shipping_estimate + (supplier_cost × fee rate)
# tier_a..d = landed / divisor (defaults 0.80 / 0.75 / 0.70 / 0.65); list = tier_d × IMPORT_LIST_PRICE_MULTIPLIER
# IMPORT_PAYMENT_FEE_RATE=0.03
# IMPORT_LIST_PRICE_MULTIPLIER=1.15
# IMPORT_SHIPPING_DEFAULT=0.65
# IMPORT_SHIPPING_NITRILE_EXAM=0.70
# IMPORT_SHIPPING_VINYL_EXAM=0.65
# IMPORT_SHIPPING_LATEX_EXAM=0.70
# IMPORT_SHIPPING_POLY=0.40
# IMPORT_SHIPPING_REUSABLE_LIGHT=0.50
# IMPORT_SHIPPING_REUSABLE_HEAVY=0.80
# IMPORT_SHIPPING_CUT_RESISTANT=0.75
# IMPORT_SHIPPING_CHEMICAL=0.85
# IMPORT_TIER_DIVISOR_A=0.80
# IMPORT_TIER_DIVISOR_B=0.75
# IMPORT_TIER_DIVISOR_C=0.70
# IMPORT_TIER_DIVISOR_D=0.65
