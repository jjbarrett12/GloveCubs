# Glovecubs server
PORT=3004
NODE_ENV=production
JWT_SECRET=your-secret-key-change-in-production

# One-time first admin: node scripts/bootstrap-admin.js
# Canonical identity = Supabase Auth UUID (JWT `id` after POST /api/auth/login). Do not commit real passwords.
# BOOTSTRAP_ADMIN_EMAIL=you@company.com
# BOOTSTRAP_ADMIN_PASSWORD=
#
# First-admin verification checklist (after bootstrap):
# 1) Supabase Auth: user exists with confirmed email.
# 2) public.users: one row with id = auth UUID, BOOTSTRAP_ADMIN_EMAIL, is_approved=1.
# 3) public.app_admins: row with auth_user_id = same UUID (required for admin UI).
# 4) POST /api/auth/login returns token; decode JWT — `id` must equal auth UUID.
# 5) GET /api/auth/me with Bearer token returns is_admin: true.

# Supabase (required for Save product, CSV import, bulk import). In production set in host env (Vercel/Render/Railway) and redeploy.
# Service role key may be JWT (eyJ...) or sb_secret_... — never commit the real key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Staging smoke tests (`npm run smoke:staging` / `scripts/smoke-staging.mjs`)
# API_BASE=http://127.0.0.1:3004
# SMOKE_USER_EMAIL=
# SMOKE_USER_PASSWORD=
# SMOKE_ADMIN_JWT=   # optional; admin-only endpoints if buyer login is not admin

# Optional: Postgres connection string for regenerating TypeScript DB types (`npm run gen:db-types`).
# Supabase Dashboard → Project Settings → Database → URI (use pooler or direct).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Bulk Import worker (cron or external caller): require this header to run POST /api/internal/import/run
INTERNAL_CRON_SECRET=your-cron-secret

# Optional AR automation: `npm run ar:aging-hold` (or cron). Sets net_terms_status to on_hold when any open invoice
# is at least this many days past due (approved companies only). Omit or leave empty to disable.
# AR_AUTO_ON_HOLD_DAYS_PAST_DUE=60
# AR_AUTO_ON_HOLD_DRY_RUN=1

# Public URL (for password reset links and emails). Also used to inject admin API base URL into the page.
DOMAIN=https://glovecubs.com
# Or: BASE_URL=https://glovecubs.com
# Or set explicitly for admin/API: GLOVECUBS_MAIN_API_URL=https://glovecubs.com

# Email (optional – omit to skip sending). Used for: order confirmation to customer, PO to vendor, contact form, admin notifications.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@glovecubs.com
# Admin receives contact form, new order, and RFQ notifications:
# ADMIN_EMAIL=sales@glovecubs.com

# Fishbowl Inventory (optional – omit to disable integration)
# FISHBOWL_BASE_URL=https://your-fishbowl-server:2456
# FISHBOWL_USERNAME=your_fishbowl_username
# FISHBOWL_PASSWORD=your_fishbowl_password
# FISHBOWL_APP_NAME=Glovecubs
# FISHBOWL_APP_ID=9001
# FISHBOWL_MFA_CODE=123456
# Optional: secret for Fishbowl to poll customer export file (GET /api/fishbowl/export-customers-file?secret=XXX)
# FISHBOWL_EXPORT_SECRET=your-secret-for-fishbowl-polling

# Add Product by URL & Bulk Import (AI-assisted). Admin only. Optional — fallback to rule-based normalize.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Or: AI_MODEL=gpt-4o-mini

# Optional: append parse/save logs (one JSON line per event) for debugging
# PARSE_LOG_PATH=data/parse-logs.jsonl

# Stripe (credit card & ACH). Optional — omit to disable Stripe; card/ACH orders still accepted but no payment capture.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...   (use in front end for Stripe.js)
# STRIPE_WEBHOOK_SECRET=whsec_...      (for payment_intent.succeeded webhook)
# Front end needs NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY or window.STRIPE_PUBLISHABLE_KEY for Stripe.js.

# Storefront analytics (optional). Exposed read-only via GET /api/config — never put secrets here.
# GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# POSTHOG_KEY=phc_...            (project API key from PostHog)
# POSTHOG_HOST=https://us.i.posthog.com   (EU: https://eu.i.posthog.com)

# Cart / checkout / order creation (lib/commerce-shipping.js). GET /api/commerce/shipping-config mirrors these for the storefront.
# Invoice/PDF uses the shipping amount stored on the order row (not recomputed from env).
# FREE_SHIPPING_THRESHOLD=500   # subtotal >= this → $0 shipping (set 0 for always-free shipping)
# FLAT_SHIPPING_RATE=25         # shipping when subtotal is below the threshold
# MIN_ORDER_AMOUNT=200          # block checkout below this subtotal; set 0 to disable minimum

# Optional: admin analytics only (GET /api/admin/analytics/shipping-margin). Does not affect checkout.
# Set rough carrier/fulfillment cost assumptions to estimate shipping-side contribution — leave unset to show “not modeled”.
# At order creation, the same assumptions (if set) are stored on orders.estimated_fulfillment_cost_usd for historical reporting.
# ANALYTICS_ASSUMED_CARRIER_COST_WHEN_CUSTOMER_PAYS_SHIPPING=12
# ANALYTICS_ASSUMED_CARRIER_COST_WHEN_FREE_SHIPPING_TO_CUSTOMER=18

# Tax Configuration (nexus-based sales tax)
# BUSINESS_STATE=CA                    (2-letter state code where business has nexus)
# BUSINESS_TAX_RATE=0.0825             (tax rate as decimal, e.g., 0.0825 = 8.25%)
# Tax is only collected on orders shipping to BUSINESS_STATE.
# For multi-state nexus or advanced tax, integrate Avalara or TaxJar (see lib/tax.js).

# AI layer (glove-finder, invoice extract/recommend). Server-side only.
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=...   (when AI_PROVIDER=gemini)
