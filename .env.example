# Glovecubs server
PORT=3004
NODE_ENV=production
JWT_SECRET=your-secret-key-change-in-production

# Site owner(s) get full admin access even without app_admins. Comma-separated emails (e.g. you@company.com).
# OWNER_EMAIL=you@company.com

# Supabase (required for Save product, CSV import, bulk import). In production set in host env (Vercel/Render/Railway) and redeploy.
# Service role key may be JWT (eyJ...) or sb_secret_... — never commit the real key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Bulk Import worker (cron or external caller): require this header to run POST /api/internal/import/run
INTERNAL_CRON_SECRET=your-cron-secret

# Public URL (for password reset links and emails). Also used to inject admin API base URL into the page.
DOMAIN=https://glovecubs.com
# Or: BASE_URL=https://glovecubs.com
# Or set explicitly for admin/API: GLOVECUBS_MAIN_API_URL=https://glovecubs.com

# Email (optional – omit to skip sending). Used for: order confirmation to customer, PO to vendor, contact form, admin notifications.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@glovecubs.com
# Admin receives contact form, new order, and RFQ notifications:
# ADMIN_EMAIL=sales@glovecubs.com

# Fishbowl Inventory (optional – omit to disable integration)
# FISHBOWL_BASE_URL=https://your-fishbowl-server:2456
# FISHBOWL_USERNAME=your_fishbowl_username
# FISHBOWL_PASSWORD=your_fishbowl_password
# FISHBOWL_APP_NAME=Glovecubs
# FISHBOWL_APP_ID=9001
# FISHBOWL_MFA_CODE=123456
# Optional: secret for Fishbowl to poll customer export file (GET /api/fishbowl/export-customers-file?secret=XXX)
# FISHBOWL_EXPORT_SECRET=your-secret-for-fishbowl-polling

# Add Product by URL & Bulk Import (AI-assisted). Admin only. Optional — fallback to rule-based normalize.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Or: AI_MODEL=gpt-4o-mini

# Optional: append parse/save logs (one JSON line per event) for debugging
# PARSE_LOG_PATH=data/parse-logs.jsonl

# Stripe (credit card & ACH). Optional — omit to disable Stripe; card/ACH orders still accepted but no payment capture.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...   (use in front end for Stripe.js)
# STRIPE_WEBHOOK_SECRET=whsec_...      (for payment_intent.succeeded webhook)
# Front end needs NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY or window.STRIPE_PUBLISHABLE_KEY for Stripe.js.

# Tax Configuration (nexus-based sales tax)
# BUSINESS_STATE=CA                    (2-letter state code where business has nexus)
# BUSINESS_TAX_RATE=0.0825             (tax rate as decimal, e.g., 0.0825 = 8.25%)
# Tax is only collected on orders shipping to BUSINESS_STATE.
# For multi-state nexus or advanced tax, integrate Avalara or TaxJar (see lib/tax.js).

# AI layer (glove-finder, invoice extract/recommend). Server-side only.
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=...   (when AI_PROVIDER=gemini)
