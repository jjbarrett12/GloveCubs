# AI (required for Glove Finder and Invoice AI)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Supabase (server-only: used by API routes for products, ai_events, etc.)
# Do not expose SUPABASE_SERVICE_ROLE_KEY to the client.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Main GloveCubs site (Express app). Used for "Full site" link and API proxy.
# e.g. http://localhost:3004 when Express runs there
# NEXT_PUBLIC_GLOVECUBS_API=http://localhost:3004

# Admin API proxy (local dev: UI on :3004, API on :3001).
# Rewrites /api/admin/* from this app to the real API. Set both for consistency.
# GLOVECUBS_ADMIN_API_ORIGIN=http://localhost:3001
# NEXT_PUBLIC_GLOVECUBS_ADMIN_API_ORIGIN=http://localhost:3001
