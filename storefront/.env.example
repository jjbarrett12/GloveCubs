PORT=3004
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ADMIN_LEADS_SECRET=
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AI (Glove Finder, Invoice AI) — set OPENAI_API_KEY for local/dev features that call OpenAI.
AI_PROVIDER=openai
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# AI_MAX_CANDIDATES=30
# AI_RATE_LIMIT_RPM=30

# Optional: legacy main-site URL for homepage only (src/lib/api.ts).
# NEXT_PUBLIC_GLOVECUBS_API=

# Homepage map (Service area section)
# Default embed uses Google Maps output=embed (no JavaScript API key required).
# Optional: replace iframe src entirely (paste full embed URL from Google Maps → Share → Embed).
# NEXT_PUBLIC_HOME_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...
# Set to disable iframe and show static fallback + “Open in Google Maps” CTA:
# NEXT_PUBLIC_HOME_MAP_DISABLED=true
