# AI (required for Glove Finder and Invoice AI)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Supabase — server (Route Handlers, Server Components). Never expose service role to the browser.
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...

# Supabase — public anon client (safe for NEXT_PUBLIC_*). Same project URL as above; use anon key from Dashboard → API.
# Required if any route uses createBrowserClient / NEXT_PUBLIC vars (e.g. admin flows that read session).
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: legacy "full site" URL for homepage only (not used by /store or lead APIs).
# NEXT_PUBLIC_GLOVECUBS_API=https://glovecubs.com

# Lead & contact email (server-only). Admin notification uses ADMIN_EMAIL, or SMTP_USER, or sales@glovecubs.com.
# ADMIN_EMAIL=sales@glovecubs.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@glovecubs.com

# /admin/leads: In production (NODE_ENV=production), ADMIN_LEADS_SECRET is required or the route returns 404.
# Open /admin/leads?secret=YOUR_TOKEN — token must match exactly.
# ADMIN_LEADS_SECRET=
