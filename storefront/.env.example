# Next dev server port (default 3005 so repo root `npm run dev` can own 3004 for Express APIs).
# Canonical HTML: this app. Express should set STOREFRONT_PUBLIC_ORIGIN to this origin (see ../ROUTE_OWNERSHIP.md).
PORT=3005

# --- Request pricing leads (server-only) ---
# Required to accept POST /api/leads/request-pricing (otherwise 503).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional client Supabase (if you add browser-side queries later).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Buyer read-only order history (/account/orders). When unset or false, shows an order-ready shell only.
# FEATURE_GC_ORDER_HISTORY=1

# Optional: reorder-to-quote API + account order reorder CTA (OR with FEATURE_GC_ORDER_HISTORY). Server-gated; no DB writes.
# FEATURE_GC_REORDER_TO_QUOTE=1

# Inbound lead notification recipient for POST /api/leads/request-pricing (see getAdminNotificationEmail).
# Defaults to SMTP_USER then sales@glovecubs.com if unset.
ADMIN_EMAIL=

# SMTP (Nodemailer) — required for lead notification email. Resend-only env vars are NOT read by this route.
# If unset or send fails, the API still returns 200 with emailDelivered: false.
# Production (Vercel) example shape:
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_FROM=GloveCubs <hello@glovecubs.com>
#   ADMIN_EMAIL=hello@glovecubs.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Admin access ---
# Admin HTML routes use Supabase session + public.admin_users (see src/app/admin/layout.tsx).
# No shared query-secret is required for /admin navigation.
#
# Local dev: create/reset auth + admin_users (password from env only; never commit):
#   GC_LOCAL_AUTH_BOOTSTRAP_PASSWORD=… GC_ALLOW_REMOTE_SUPABASE_AUTH_BOOTSTRAP=1 npm run bootstrap-local-admin -- hello@glovecubs.com
# Remote (*.supabase.co): the GC_ALLOW_REMOTE… flag is required so production mistakes are harder.

# Optional: POST /api/internal/* (when routes exist). Header: x-gc-internal-secret: <value>
# INTERNAL_API_SECRET=

# CatalogOS (server → CatalogOS for admin import proxies, invoice resolve, etc.)
# CATALOGOS_INTERNAL_URL=https://your-catalogos-host
# INTERNAL_API_KEY=            # required in production (must NOT be dev-internal-key)
# Optional: override default 25s timeout for CatalogOS internal fetch
# CATALOGOS_INTERNAL_TIMEOUT_MS=25000
# Optional operator deep-link base (browser) — e.g. Products page "Open CatalogOS" uses NEXT_PUBLIC_CATALOGOS_URL when set.
# NEXT_PUBLIC_CATALOGOS_URL=https://your-catalogos-host

# AI (Glove Finder, Invoice extract/recommend) — required for those API routes to work.
AI_PROVIDER=openai
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# AI_MAX_CANDIDATES=30
# AI_RATE_LIMIT_RPM=30

# Express API origin only (`server.js` /api/*) — NOT the marketing site URL.
# Local: http://localhost:3004  |  Production target host: https://api.glovecubs.com
# Use storefront/src/lib/api.ts (`getExpressCommerceApiOrigin`, `buildExpressCommerceApiUrl`) in code; avoid hardcoding.
# NEXT_PUBLIC_GLOVECUBS_API=http://localhost:3004

# Homepage map (Service area section)
# Default embed uses Google Maps output=embed (no JavaScript API key required).
# Optional: replace iframe src entirely (paste full embed URL from Google Maps → Share → Embed).
# NEXT_PUBLIC_HOME_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...
# Set to disable iframe and show static fallback + “Open in Google Maps” CTA:
# NEXT_PUBLIC_HOME_MAP_DISABLED=true
