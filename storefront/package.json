{
  "name": "glovecubs-storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env:check": "node ./scripts/check-required-env.mjs",
    "env:sync": "node ./scripts/sync-local-supabase-env.mjs",
    "predev": "node ./scripts/check-required-env.mjs",
    "dev": "next dev -p 3005",
    "dev:reset": "node ./scripts/dev-reset.mjs",
    "clean:next": "node ./scripts/clean-next.mjs",
    "clean:dev": "npm run clean:next && npm run dev",
    "dev:clean": "npm run clean:dev",
    "prebuild": "node ./scripts/guard-next-cache.mjs",
    "build": "next build",
    "build:clean": "npm run clean:next && npm run build",
    "start": "next start -p 3005",
    "start:e2e": "next start -p 3010",
    "lint": "next lint",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "verify:ui": "npm run lint && npm run lint:css && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test e2e/smoke",
    "test:smoke:ci": "npm run build && cross-env CI=true playwright test e2e/smoke",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.460.0",
    "next": "^14.2.0",
    "nodemailer": "^8.0.0",
    "openai": "^4.104.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-simple-maps": "^3.0.0",
    "tailwind-merge": "^2.5.4",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.47",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
