{
  "name": "glovecubs",
  "version": "1.0.0",
  "description": "B2B E-commerce platform for disposable and reusable work gloves",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "seed": "node seed.js",
    "diagnose:products": "node scripts/diagnose-products.mjs",
    "enrich:hospeco-images": "node scripts/enrich-hospeco-images.mjs",
    "test": "node --test \"tests/*.test.js\"",
    "test:auth": "node --test tests/auth.test.js",
    "test:checkout-http": "node tests/checkout-address-api.integration.js",
    "test:parse-url": "node scripts/test-parse-url-asset.mjs",
    "test:parse-url:live": "node scripts/test-parse-url-asset.mjs --live",
    "test:import-attributes": "node scripts/test-import-attributes.cjs",
    "scrape:hospeco": "tsx scripts/hospeco-image-scraper.ts",
    "email-routing:worker": "node lib/email-routing/worker.js --once --max=10",
    "load:smoke": "cd load-tests && k6 run --env PROFILE=smoke scenarios/mixed-workload.js",
    "load:normal": "cd load-tests && k6 run --env PROFILE=normal scenarios/mixed-workload.js",
    "load:stress": "cd load-tests && k6 run --env PROFILE=stress scenarios/mixed-workload.js",
    "load:report": "node load-tests/scripts/generate-report.js",
    "gen:db-types": "node scripts/gen-supabase-types.mjs",
    "smoke:staging": "node scripts/smoke-staging.mjs --all",
    "smoke:reconcile": "node scripts/smoke-staging.mjs --reconcile-only",
    "check:po-mapping": "node scripts/check-po-mapping-health.js",
    "ar:aging-hold": "node scripts/ar-aging-auto-hold.js",
    "verify:structural-cleanup": "node scripts/run-structural-verification.mjs",
    "check:v2-catalog": "node scripts/check-v2-catalog-guardrails.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.0",
    "openai": "^6.25.0",
    "stripe": "^17.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "csv-parse": "^5.5.6",
    "csv-parser": "^3.2.0",
    "csv-stringify": "^6.6.0",
    "minimist": "^1.2.8",
    "playwright": "^1.49.0",
    "tsx": "^4.19.2",
    "xlsx": "^0.18.5"
  }
}
